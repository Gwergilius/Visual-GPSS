# Normalize all text files to LF on commit
* text=auto eol=lf

# Source and config
*.cs        text eol=lf
*.csproj    text eol=lf
*.slnx      text eol=lf
*.sln       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.puml      text eol=lf
*.mmd       text eol=lf

# Windows scripts keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line-ending processing
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.dll       binary
*.exe       binary
*.pdb       binary
